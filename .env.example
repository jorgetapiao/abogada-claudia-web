# Copiá este archivo a .env.local y completá los valores.

# --- MongoDB ---
MONGODB_URI=""

# --- NextAuth v5 (Auth.js) ---
# Generá el secreto con: npx auth secret   (o: openssl rand -base64 32)
AUTH_SECRET=""

# --- Bunny.net ---
# Storage Zone (archivos)
BUNNY_STORAGE_ZONE=""
BUNNY_STORAGE_PASSWORD=""            # AccessKey del Storage (SECRETO, solo servidor)
BUNNY_STORAGE_REGION="storage.bunnycdn.com"  # host del Storage (según tu región)
# Pull Zone / CDN (entrega pública)
BUNNY_CDN_URL=""
# Token Authentication (opcional, solo si algún día usás URLs firmadas)
BUNNY_CDN_TOKEN_KEY=""
